// Prisma schema — Bond Management
// Run `npm run prisma:migrate` after setting DATABASE_URL to create the tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  admin
  backoffice
  analyste
  systeme
}

enum BondStatus {
  active
  suspended
  matured
}

enum HistoryUseCase {
  UC02
  UC03
  UC05
  UC06
  UC08
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AppRole
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  historyEntries HistoryEntry[]

  @@map("users")
}

model Bond {
  id           String     @id @default(cuid())
  isin         String     @unique
  name         String
  /// valeur nominale, en MAD
  nominal      Decimal    @db.Decimal(18, 2)
  /// taux facial, en %
  couponRate   Decimal    @db.Decimal(6, 3)
  /// paiements de coupon par an (1, 2, 4 ou 12)
  frequency    Int
  issueDate    DateTime   @db.Date
  maturityDate DateTime   @db.Date
  /// dernier prix de marché connu (% du nominal), null si jamais coté
  price        Decimal?   @db.Decimal(8, 3)
  valueDate    DateTime?  @db.Date
  valueType    String?
  isFloating   Boolean    @default(false)
  isAmortizing Boolean    @default(false)
  amortizationDeferral String?
  schedule     String?
  comments     String?
  wgRate       Decimal?   @db.Decimal(8, 6)
  ctRate       Decimal?   @db.Decimal(8, 6)
  cfgRate      Decimal?   @db.Decimal(8, 6)
  status       BondStatus @default(active)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  historyEntries HistoryEntry[]
  cashFlows      CashFlow[]

  @@map("bonds")
}

model CashFlow {
  id             String    @id @default(cuid())
  source         String
  cashFlowDate   DateTime  @db.Date
  settlementDate DateTime? @db.Date
  principal      Decimal   @default(0) @db.Decimal(18, 2)
  outstanding    Decimal?  @db.Decimal(18, 2)
  couponRate     Decimal?  @db.Decimal(10, 8)
  grossCoupon    Decimal   @default(0) @db.Decimal(18, 2)
  bondId         String?
  bond           Bond?     @relation(fields: [bondId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())

  @@unique([source, cashFlowDate])
  @@index([bondId, cashFlowDate])
  @@map("cash_flows")
}

model YieldCurvePoint {
  id              String    @id @default(cuid())
  valuationDate   DateTime  @db.Date
  maturityDate    DateTime  @db.Date
  daysToMaturity  Int
  weightedRate    Decimal   @db.Decimal(10, 8)
  moneyMarketRate Decimal?  @db.Decimal(10, 8)
  actuarialRate   Decimal?  @db.Decimal(10, 8)
  createdAt       DateTime  @default(now())

  @@unique([valuationDate, maturityDate])
  @@map("yield_curve_points")
}

/// Points de la feuille "Courbe ZC" du fichier Pricer.
model ZeroCouponCurvePoint {
  id            String   @id @default(cuid())
  valuationDate DateTime @db.Date
  maturityMode  String
  maturity      Int
  zeroCouponRate Decimal @db.Decimal(12, 10)
  createdAt     DateTime @default(now())

  @@unique([valuationDate, maturityMode, maturity])
  @@map("zero_coupon_curve_points")
}

model HistoryEntry {
  id        String         @id @default(cuid())
  ucId      HistoryUseCase
  label     String
  detail    String
  timestamp DateTime       @default(now())

  bondId String?
  bond   Bond?   @relation(fields: [bondId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("history_entries")
  @@index([timestamp])
}
